# Maintainer: Thomas Dreibholz <thomas.dreibholz@gmail.com>
pkgname=socketapi
pkgver=2.2.28
pkgrel=1
pkgdesc="Socket API library for the SCTPLIB user-space SCTP implementation"
url="https://www.nntb.no/~dreibh/sctplib/"
arch="all"
license="GPL-3.0-or-later"
depends=""
makedepends="autoconf automake g++ glib-dev libtool sctplib-dev"
subpackages="$pkgname-dev"
source="https://www.nntb.no/~dreibh/sctplib/download/$pkgname-$pkgver.tar.gz"
options="!check" # No test suite defined in the upstream spec

prepare() {
	default_prepare
	autoreconf -i
}

build() {
	export CFLAGS="$CFLAGS -ffat-lto-objects"
	export CXXFLAGS="$CXXFLAGS -ffat-lto-objects"

	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--localstatedir=/var \
		--enable-sctp-over-udp \
		--disable-maintainer-mode
	make
}

package() {
	make DESTDIR="$pkgdir" install

	# Delete libtool archive files as per Alpine policy
	find "$pkgdir" -name "*.la" -delete
}

sha512sums="
49b131e13b2859086c78cdb3f28ace004ae4760c3685148aeadb090067a715e5ea2d4dd85a73b95e28826975d2e958822acc08124e3d0c20a4f1dbf0b453a284  socketapi-2.2.28.tar.gz
"
